{
  "buildCommand": "cd MyApp && npm run build:web",
  "outputDirectory": "MyApp/dist",
  "installCommand": "npm install && npm install --prefix MyApp",
  "rewrites": [
    {
      "source": "/api/admin-data",
      "destination": "/api/admin?action=admin-data"
    },
    {
      "source": "/api/admin/:action",
      "destination": "/api/admin?action=:action"
    },
    {
      "source": "/api/auth/:action",
      "destination": "/api/auth?action=:action"
    },
    {
      "source": "/api/generate-design",
      "destination": "/api/design?action=generate-design"
    },
    {
      "source": "/api/generate-design-custom",
      "destination": "/api/design?action=generate-design-custom"
    },
    {
      "source": "/api/regenerate-design",
      "destination": "/api/design?action=regenerate-design"
    },
    {
      "source": "/api/meta/track-event",
      "destination": "/api/tracking?action=meta-track-event"
    },
    {
      "source": "/api/pinterest/track-event",
      "destination": "/api/tracking?action=pinterest-track-event"
    },
    {
      "source": "/api/tiktok/track-event",
      "destination": "/api/tracking?action=tiktok-track-event"
    },
    {
      "source": "/api/subscription/:action",
      "destination": "/api/subscription?action=:action"
    },
    {
      "source": "/api/usage/:action",
      "destination": "/api/usage?action=:action"
    },
    {
      "source": "/api/webhooks/:action",
      "destination": "/api/webhooks?action=:action"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'self' 'unsafe-inline' 'unsafe-eval' https://js.stripe.com https://www.googletagmanager.com https://www.google-analytics.com https://connect.facebook.net https://s.pinimg.com https://analytics.tiktok.com; frame-src * 'self' https://js.stripe.com https://hooks.stripe.com https://www.googletagmanager.com; connect-src * 'self' https://www.google-analytics.com https://www.googletagmanager.com https://analytics.google.com https://ct.pinterest.com https://analytics.tiktok.com; img-src * 'self' data: blob: https://www.google-analytics.com https://www.googletagmanager.com https://www.facebook.com https://ct.pinterest.com https://analytics.tiktok.com; style-src * 'self' 'unsafe-inline';"
        }
      ]
    }
  ]
}
